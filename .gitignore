# Node.js dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment Variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env

# Build Output
frontend/dist/
frontend/dist-ssr/
build/
coverage/

# Backend Uploads / Temporary Files
backend/uploads/*
!backend/uploads/.gitkeep
backend/uploads/resumes/*
!backend/uploads/resumes/.gitkeep
backend/.env

# IDEs and Editors
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS metadata
.DS_Store
Thumbs.db

# Misc project generated files
repomix-output.xml
*.pid

# Optional npm cache and history
.npm
.eslintcache
.node_repl_history


